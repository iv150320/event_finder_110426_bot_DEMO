# ============================================
# Event Finder Bot — event_finder_110426_bot
# ============================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Allowed Telegram User IDs (comma-separated)
# Your user ID: 71300950
ALLOWED_USERS=71300950

# ============================================
# Notion Integration
# ============================================
# Notion API key (ntn_...) from https://www.notion.so/my-integrations
NOTION_API_KEY=YOUR_NOTION_API_KEY_HERE

# Parent Page ID — pages will be created as children of this page
# Use the page ID from your Notion workspace root
NOTION_PARENT_PAGE_ID=YOUR_PARENT_PAGE_ID_HERE

# ============================================
# Calendar / ICS Feed
# ============================================
# External host IP or domain for calendar links
EXTERNAL_HOST=your-server-ip-or-domain

# ICS Feed port
ICS_PORT=8081

# ============================================
# Scheduler Configuration
# ============================================
# Cities to scan (comma-separated slugs: msk, spb, ekb, nsk, kzn, sochi)
SCHEDULER_CITIES=msk

# Days after which old events are cleaned from DB
SCHEDULER_CLEANUP_DAYS=60

# ============================================
# NVIDIA NIM API (DeepSeek V3.2 for event analysis)
# ============================================
# API key from https://build.nvidia.com/
NVIDIA_API_KEY=YOUR_NVIDIA_API_KEY_HERE
# Model for topic analysis
NVIDIA_MODEL=deepseek-ai/deepseek-v3.2
